{
  "name": "coastal",
  "type": "dark",
  "colors": {
    "editor.background": "#0e1210",
    "editor.foreground": "#C8C0B8"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": { "foreground": "#4E6058" }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": { "foreground": "#E8B46A", "fontStyle": "bold" }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#7EBFC3" }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": { "foreground": "#A8C89A" }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex"
      ],
      "settings": { "foreground": "#C3A6E8" }
    },
    {
      "scope": [
        "variable.parameter",
        "entity.name.variable.parameter"
      ],
      "settings": { "foreground": "#D4974A" }
    },
    {
      "scope": [
        "variable.other.constant",
        "support.constant",
        "constant.language",
        "constant.language.boolean",
        "variable.other.enummember"
      ],
      "settings": { "foreground": "#E89A7A" }
    },
    {
      "scope": [
        "variable.other.property",
        "support.type.property-name",
        "meta.object-literal.key",
        "entity.name.tag.css",
        "support.type.property-name.css"
      ],
      "settings": { "foreground": "#9DC4C7" }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest"
      ],
      "settings": { "foreground": "#ACA69E" }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.section"
      ],
      "settings": { "foreground": "#5A6E64" }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html",
        "punctuation.definition.tag"
      ],
      "settings": { "foreground": "#E8B46A" }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": { "foreground": "#9DC4C7" }
    },
    {
      "scope": [
        "support.class",
        "entity.name.type",
        "entity.other.inherited-class"
      ],
      "settings": { "foreground": "#7EBFC3" }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#C8C0B8" }
    },
    {
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression.typeof",
        "keyword.operator.expression.instanceof",
        "keyword.operator.expression.of",
        "keyword.operator.expression.in",
        "keyword.operator.expression.void",
        "keyword.operator.expression.delete"
      ],
      "settings": { "foreground": "#E8B46A", "fontStyle": "bold" }
    },
    {
      "scope": [
        "string.template punctuation.definition.template-expression",
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": { "foreground": "#D4974A" }
    },
    {
      "scope": [
        "support.type.builtin",
        "entity.name.type.class"
      ],
      "settings": { "foreground": "#7EBFC3" }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": { "foreground": "#E8B46A", "fontStyle": "bold" }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": { "foreground": "#A8C89A" }
    }
  ]
}
